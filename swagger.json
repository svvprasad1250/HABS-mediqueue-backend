{
    "openapi": "3.0.0",
    "info": {
        "title": "mediQueue API",
        "version": "1.0.0"
    },
    "components":{
        "securitySchemes":{
            "BearerAuth":{
                "type":"http",
                "scheme":"bearer",
                "bearerFormat":"JWT"
            }
        }
    },
    "tags":[
        {
            "name":"Auth"
        },
        {
            "name":"Hospitals"
        },
        {
            "name":"users"
        },
        {
            "name":"appointments"
        }
    ],
    "paths":{
        "/api/auth/register":{
            "post":{
                "tags":["Auth"],
                "summary":"Register new user with profile image",
                "requestBody":{
                "required":true,
                "content":{
                    "multipart/form-data":{
                    "schema":{
                        "type":"object",
                        "properties":{
                        "name":{
                            "type":"string",
                            "example":"Steve"
                        },
                        "email":{
                            "type":"string",
                            "example":"steeve@yopmail.com"
                        },
                        "password":{
                            "type":"string",
                            "example":"steeve@1234"
                        },
                        "phone":{
                            "type":"string",
                            "example":"1234567890"
                        },
                        "role":{
                            "type":"string",
                            "example":"patient"
                        },
                        "department":{
                            "type":"string",
                            "example":"Cardiology"
                        },
                        "image":{
                            "type":"string",
                            "format":"binary"
                        }
                        },
                        "required":["name","email","password"]
                    }
                    }
                }
                },
                "responses":{
                    "201":{
                        "description":"User registered successfully"
                    }
                }
            }
        },
        "/api/auth/login":{
            "post":{
                "tags":["Auth"],
                "summary":"login new user",
                "requestBody":{
                    "required":true,
                    "content":{
                        "application/json":{
                            "schema":{
                                "type":"object",
                                "properties":{
                                    "email":{
                                        "type":"string",
                                        "example":"steeve@yopmail.com"
                                    },
                                    "password":{
                                        "type":"string",
                                        "example":"steeve@1234"
                                    }
                                },
                                "required":["email","password"]
                            }
                        }
                    }
                },
                "responses":{
                    "201":{
                        "description":"user logged in successfully!"
                    }
                }
            }
        },
        "/api/auth/refresh":{
            "post":{
                "tags":["Auth"],
                "summary":"Generate new access token using refresh token",
                "requestBody":{
                    "required":true,
                    "content":{
                        "application/json":{
                            "schema":{
                                "type":"object",
                                "properties":{
                                    "refreshToken":{
                                        "type":"string",
                                        "example":"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9"
                                    }
                                },
                                "required": ["refreshToken"]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "New access token generated successfully"
                    },
                    "401": {
                        "description": "Refresh token required"
                    },
                    "403": {
                        "description": "Invalid refresh token"
                    }
                }
            }
        },

        "/api/users/current-user":{
            "get":{
                "tags":["users"],
                "summary":"get current user",
                "security":[
                    {
                        "BearerAuth":[]
                    }
                ],
                "responses":{
                    "200":{
                        "description":" successfully!"
                    }
                }
            }
        },
        "/api/users/doctors":{
            "get":{
                "tags":["users"],
                "summary":"get doctors",
                "security":[
                    {
                        "BearerAuth":[]
                    }
                ],
                "responses":{
                    "200":{
                        "description":" successfully!"
                    }
                }
            }
        },
        "/api/users/patients":{
            "get":{
                "tags":["users"],
                "summary":"get patients",
                "security":[
                    {
                        "BearerAuth":[]
                    }
                ],
                "responses":{
                    "200":{
                        "description":" successfully!"
                    }
                }
            }
        },
        "/api/users/darkmode":{
            "patch":{
                "tags":["users"],
                "summary":"change user darkmode",
                "security":[
                    {
                        "BearerAuth":[]
                    }
                ],
                "requestBody":{
                    "required":true,
                    "content":{
                        "application/json":{
                            "schema":{
                                "type":"object",
                                "properties":{
                                    "darkMode":{
                                        "type":"boolean",
                                        "example":true
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Dark mode updated successfully"
                    },
                    "400": {
                        "description": "Invalid input"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                }
            }
        },
        "/api/users/profile-update":{
            "patch":{
                "tags":["users"],
                "summary":"update the user credentials",
                "security":[
                    {
                        "BearerAuth":[]
                    }
                ],
                "requestBody":{
                    "required":true,
                    "content":{
                        "multipart/form-data":{
                            "schema":{
                                "type":"object",
                                "properties":{
                                    "name":{
                                        "type":"string",
                                        "example":"ram"
                                    },
                                    "phone":{
                                        "type":"string",
                                        "example":""
                                    },
                                    "image":{
                                        "type":"string",
                                        "format":"binary"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "updated successfully"
                    },
                    "400": {
                        "description": "Invalid input"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                }
            }
        },

        "/api/appointments":{
            "get":{
                "tags":["appointments"],
                "summary":"get appointments",
                "security":[
                    {
                        "BearerAuth":[]
                    }
                ],
                "responses":{
                    "201":{
                        "description":" successfully!"
                    }
                }
            },
            "post": {
                "tags": ["appointments"],
                "summary": "Create new appointment",
                "security":[
                    {
                        "BearerAuth":[]
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "patient":{
                                        "type":"object",
                                        "properties":{
                                            "name":{
                                                "type":"string",
                                                "example":"Ramesh Kumar"
                                            },
                                            "age":{
                                                "type":"integer",
                                                "example":62
                                            },
                                            "gender":{
                                                "type": "string",
                                                "enum": ["Male", "Female", "Other"],
                                                "example": "Male"
                                            },
                                            "phone":{
                                                "type": "string",
                                                "example": "9876543210"
                                            }
                                        },
                                        "required":["name"]
                                    },
                                    "doctor":{
                                        "type":"string",
                                        "example":"69abd313ed25c94051820110"
                                    },
                                    "department": {
                                        "type": "string",
                                        "example": "Cardiology"
                                    },
                                    "appointmentDate": {
                                        "type": "Date",
                                        "example": "2026-03-07"
                                    },
                                    "timeSlot": {
                                        "type": "string",
                                        "example": "10:00 AM"
                                    },
                                    "reason":{
                                        "type":"string",
                                        "example":"chest pain"
                                    }
                                },
                                "required": ["patient","doctor", "department","appointmentDate","timeSlot","reason"]
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Appointment created successfully"
                    }
                }
            }
        },
        "/api/appointments/{id}/status":{
            "patch":{
                "tags":["appointments"],
                "summary":"change appointment status by dr",
                "security":[
                    {
                        "BearerAuth":[]
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "description": "Appointment ID",
                        "schema": {
                        "type": "string",
                        "example": "69abe37aaebbd70281a11bc0"
                        }
                    }
                ],
                "requestBody":{
                    "required":true,
                    "content":{
                        "application/json":{
                            "schema":{
                                "type":"object",
                                "properties":{
                                    "status":{
                                        "type":"string",
                                        "enum": ["pending", "cancelled", "completed"],
                                        "example": "completed"
                                    },
                                    "doctorNote":{
                                        "type":"string",
                                        "nullabel":true,
                                        "example":"Doctor unavailable today"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Appointment status updated successfully"
                    },
                    "400": {
                        "description": "Invalid input"
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "403": {
                        "description": "Forbidden - only specific user can update"
                    },
                    "404": {
                        "description": "Appointment not found"
                    }
                }
            }
        },
        "/api/appointments/{id}/rescheduleAppointment":{
            "patch":{
                "tags":["appointments"],
                "summary":"appointment reschedule timeslot, appointment date",
                "security":[
                    {
                        "BearerAuth":[]
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "description": "Appointment ID",
                        "schema": {
                        "type": "string",
                        "example": "69abe37aaebbd70281a11bc0"
                        }
                    }
                ],
                "requestBody":{
                    "required":true,
                    "content":{
                        "application/json":{
                            "schema":{
                                "type":"object",
                                "properties":{
                                    "appointmentDate":{
                                        "type":"string",
                                        "example": "2026-03-09"
                                    },
                                    "timeSlot":{
                                        "type":"string",
                                        "example":"4:00 PM"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Appointment status updated successfully"
                    },
                    "400": {
                        "description": "Invalid input"
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "403": {
                        "description": "Forbidden - only specific user can update"
                    },
                    "404": {
                        "description": "Appointment not found"
                    }
                }
            }
        },
        "/api/appointments/{id}":{
            "delete": {
                "tags":["appointments"],
                "summary": "appointment deleted",
                "security":[
                    {
                        "BearerAuth":[]
                    }
                ],
                "parameters":[
                    {
                        "name":"id",
                        "in":"path",
                        "required":true,
                        "schema":{
                            "type":"string"
                        }
                    }
                ],
                "requestBody":{
                    "required":false,
                    "content":{
                        "application/json":{
                            "schema":{
                                "type":"object",
                                "properties":{
                                    "reasonForCancellation":{
                                        "type":"string",
                                        "example":"Booked wrong doctor"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Success"
                    },
                    "404": {
                        "description": "Contact not found"
                    }
                }
            }
        }
    }
}